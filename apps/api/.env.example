# Redis (REQUIRED - used by redis client for caching)
# Format: redis://[username]:[password]@[host]:[port]
# For Upstash: redis://default:PASSWORD@HOST:6379
# For local: redis://localhost:6379
REDIS_URL="redis://default:password@your-redis.upstash.io:6379"

# Upstash Redis REST API (for MCP server)
# Get from Upstash Console → REST API → Copy URL and Token
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Clockwork Pro API
CLOCKWORK_API_BASE_URL=https://api.clockwork.report/v1
CLOCKWORK_API_TOKEN=your-clockwork-api-token

# Atlassian / Jira
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token

JIRA_DOMAIN=your-org.atlassian.net

# Note: JIRA_FULL_COOKIE is deprecated and no longer used
# JIRA_FULL_COOKIE=your-jira-full-cookie

# Jira account ID (for lunch worklog adjustment)
# How to get: Open Jira → Profile → Account settings → URL contains accountId
JIRA_ACCOUNT_ID=61dfaa6949f1950069b0f94a

# Tenant session token for Clockwork JWT acquisition
# How to get: Open Jira → DevTools → Application → Cookies → tenant.session.token
JIRA_TENANT_SESSION_TOKEN=your-tenant-session-token

# Atlassian Forge Gateway (for timer sync)
# How to get JIRA_CLOUD_ID:
# 1. Open Jira in browser
# 2. Open DevTools → Network tab
# 3. Look for any request to /gateway/api/graphql or /rest/api/3/
# 4. Check request headers or URL for "cloudId" parameter
# 5. Or check window.ADMIN_CLOUD_ID in browser console
JIRA_CLOUD_ID=afde6ffd-9c34-4257-a163-36336cf8d953

# How to get JIRA_WORKSPACE_ID:
# 1. Open Jira → any project
# 2. Look at URL: /jira/software/projects/ACV2/
# 3. workspaceId is in network requests to /gateway/api/graphql
# 4. Check the payload: contextIds contains workspace/<workspaceId>
JIRA_WORKSPACE_ID=fefd8a92-e020-4606-8adf-3139353b0663

# FORGE_EXTENSION_ID is fixed for Clockwork Pro (optional - has default value)
FORGE_EXTENSION_ID=ari:cloud:ecosystem::extension/2f4dbb6a-b1b8-4824-94b1-42a64e507a09/725dad32-d2c5-4b58-a141-a093d70c8d34/static/global-pages

# MCP endpoint security (optional but recommended in production)
MCP_API_KEY=replace-with-strong-secret
MCP_ALLOWED_ORIGINS=http://localhost:6274
